<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ascendant Recruiting</title>
  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #ffffff;
      color: #111;
      line-height: 1.6;
    }

    .container {
      max-width: 1100px;
      margin: auto;
      padding: 40px 20px;
    }

    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 60px;
    }

    .logo {
      height: 50px;
    }

    .hero {
      text-align: center;
      margin-bottom: 80px;
    }

    .hero img {
      width: 120px;
      margin-bottom: 20px;
      filter: drop-shadow(0px 10px 25px rgba(94, 23, 235, 0.3));
      transform: translateY(0);
      transition: transform 0.3s ease;
    }

    .hero img:hover {
      transform: translateY(-8px);
    }

    h1 {
      font-size: 42px;
      margin-bottom: 10px;
      color: #5E17EB;
    }

    .tagline {
      font-size: 20px;
      font-weight: 500;
      margin-bottom: 25px;
    }

    .description {
      max-width: 700px;
      margin: auto;
      color: #555;
      font-size: 18px;
    }

    .section {
      margin-top: 60px;
      text-align: center;
    }

    .section h2 {
      color: #5E17EB;
      margin-bottom: 20px;
    }

    .cards {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 20px;
    }

    .card {
      background: #fff;
      border-radius: 12px;
      padding: 25px;
      width: 280px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
      transition: transform 0.2s ease;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .cta {
      margin-top: 80px;
      text-align: center;
    }

    .cta button {
      background: #5E17EB;
      color: #fff;
      border: none;
      padding: 15px 30px;
      font-size: 16px;
      border-radius: 8px;
      cursor: pointer;
      transition: 0.3s;
    }

    .cta button:hover {
      background: #4a11c9;
    }

    footer {
      margin-top: 80px;
      text-align: center;
      color: #777;
      font-size: 14px;
    }
  </style>
</head>

<body>

<div class="container">

  <!-- HEADER -->
  <header>
    <img src="logo-full.png" class="logo" alt="Ascendant Recruiting Logo">
  </header>

  <!-- HERO -->
  <section class="hero">
    <img src="logo-icon.png" alt="Logo Icon">

    <h1>Ascendant Recruiting</h1>
    <div class="tagline">Top Tech Talent. Delivered Fast.</div>

    <p class="description">
      Ascendant Recruiting is a specialized talent partner focused on placing high-impact professionals across artificial intelligence, machine learning, and advanced technology teams.  
      <br><br>
      We partner with high-growth startups and established companies to identify, engage, and secure top-tier talent in highly competitive markets. Our approach combines technical understanding with precision sourcing to deliver candidates who not only meet requirements—but elevate teams.  
      <br><br>
      We prioritize speed, accuracy, and long-term fit—helping companies scale with confidence.
    </p>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <h2>What We Deliver</h2>

    <div class="cards">
      <div class="card">
        <h3>AI Engineers</h3>
        <p>Machine learning, LLM, and applied AI specialists ready to make impact.</p>
      </div>

      <div class="card">
        <h3>Precision Hiring</h3>
        <p>Highly targeted candidate sourcing — no wasted time reviewing unqualified talent.</p>
      </div>

      <div class="card">
        <h3>Speed</h3>
        <p>We move faster than traditional recruiting firms to secure top candidates before competitors.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <h2>Start Hiring Top AI Talent</h2>
    <p>Let’s connect and discuss your hiring needs.</p>
    <button onclick="window.location.href='mailto:your@email.com'">
      Contact Us
    </button>
  </section>

  <!-- FOOTER -->
  <footer>
    © 2026 Ascendant Recruiting LLC
  </footer>

</div>

</body>
</html>
